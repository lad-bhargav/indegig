// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  buyer
  seller
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seller    Seller?
  buyer     Buyer?
}

model Seller {
  id       String     @id @default(cuid())
  user     User       @relation(fields: [sellerId], references: [clerkId])
  sellerId String     @unique
  products Products[]
}

model Buyer {
  id       String     @id @default(cuid())
  user     User       @relation(fields: [buyerId], references: [clerkId])
  buyerId  String     @unique
  products Products[]
}

model Products {
  id              String    @id @default(cuid())
  seller          Seller    @relation(fields: [sellerId], references: [id])
  buyer           Buyer?     @relation(fields: [buyerId], references: [id])
  sellerId        String
  buyerId         String?
  title           String
  description     String
  img             String
  price           Float
  deliveringTime  Int
  isDelivered     Boolean   @default(false)
  willdeliveredIn DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
